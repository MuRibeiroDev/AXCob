# ---- Banco (Azure SQL) ----
DB_HOST=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=

# ---- Bitrix24 (Smart Process 1200: Protestos cat 116 / Negativações cat 112) ----
BITRIX_WEBHOOK_URL=

# Analistas com webhook PRÓPRIO (criado logado como a pessoa) — usado ao protestar/
# negativar para o card sair com "Criado por" = o analista escolhido no modal.
# Numere de 1 em diante; o backend lê até parar de achar par NOME/WEBHOOK.
BITRIX_ANALISTA_1_NOME=Mariana Souza
BITRIX_ANALISTA_1_WEBHOOK=https://audaxcapitalsa.bitrix24.com.br/rest/123/abc123def456ghi789/
BITRIX_ANALISTA_2_NOME=Carlos Henrique Lima
BITRIX_ANALISTA_2_WEBHOOK=https://audaxcapitalsa.bitrix24.com.br/rest/456/jkl012mno345pqr678/

# ---- Auth (login via tabela compartilhada Ax_Caixa.users_qitech no banco SMART) ----
# Banco onde está a users_qitech (SOMENTE LEITURA p/ o AxCob):
SMART_HOST=
SMART_PORT=1433
SMART_DATABASE=
SMART_USER=
SMART_PASSWORD=
JWT_SECRET=troque-por-uma-string-aleatoria-longa
JWT_EXPIRES=12h

# ---- App ----
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Filtro padrão da carteira: comissarias | todos
VENCIDOS_TIPO_DEFAULT=todos

# ---- OpenAI (relatório de comissárias) ----
OPENAI_API_KEY=
COBRANCA_LLM_MODEL=gpt-4o-mini

# ---- Evolution API (envio WhatsApp) ----
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=
