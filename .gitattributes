# Normaliza fim de linha. O repositório guarda LF; evita que CRLF (Windows)
# vaze para os containers Linux e quebre scripts/Dockerfiles no deploy.
* text=auto

# Sempre LF (lidos/executados dentro dos containers Linux)
*.sh           text eol=lf
*.py           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.conf         text eol=lf
*.json         text eol=lf
Dockerfile     text eol=lf
.dockerignore  text eol=lf
.env.example   text eol=lf

# Binários (não normalizar)
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.woff  binary
*.woff2 binary
