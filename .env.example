# ╔══════════════════════════════════════════════════════════════╗
# ║  AxCob — .env ÚNICO (raiz). Copie para .env e preencha.        ║
# ║  Backend (NestJS), scripts e docker-compose leem deste arquivo.║
# ╚══════════════════════════════════════════════════════════════╝

# ---- Banco (Azure SQL) ----
DB_HOST=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 18 for SQL Server

# ---- Power BI (scripts de análise) ----
POWERBI_USERNAME=
POWERBI_PASSWORD=

# ---- Auth: tabela compartilhada Ax_Caixa.users_qitech (banco SMART, somente leitura) ----
SMART_HOST=
SMART_PORT=1433
SMART_USER=
SMART_PASSWORD=
SMART_DATABASE=
JWT_SECRET=troque-por-uma-string-aleatoria-longa
JWT_EXPIRES=12h

# ---- Bitrix24 (Smart Process 1200: Protestos cat 116 / Negativações cat 112) ----
BITRIX_WEBHOOK_URL=
# Analistas com webhook PRÓPRIO (numere de 1 em diante; o backend lê até parar de achar par)
# BITRIX_ANALISTA_1_NOME=Mariana Souza
# BITRIX_ANALISTA_1_WEBHOOK=https://audaxcapitalsa.bitrix24.com.br/rest/123/abc.../

# ---- OpenAI (relatório de comissárias) ----
OPENAI_API_KEY=
COBRANCA_LLM_MODEL=gpt-4o-mini

# ---- Evolution API (envio WhatsApp) ----
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=

# ---- App ----
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
VENCIDOS_TIPO_DEFAULT=todos
REL_MAX_CONCURRENT=4
